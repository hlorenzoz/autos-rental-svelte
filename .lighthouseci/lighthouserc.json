{
  "ci": {
    "collect": {
      "startServerCommand": "bun run preview --port 4173 --host 127.0.0.1",
      "startServerReadyPattern": "Local:|localhost:4173|127.0.0.1:4173",
      "url": [
        "http://127.0.0.1:4173/en/",
        "http://127.0.0.1:4173/en/vehicles/",
        "http://127.0.0.1:4173/es/vehiculos/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:seo": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
